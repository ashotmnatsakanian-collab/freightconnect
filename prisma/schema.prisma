generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Salon {
  id        String   @id @default(cuid())
  name      String
  type      String   // femme | homme | mixte | nail
  address   String?
  phone     String?
  email     String?
  ownerId   String
  settings  String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients      Client[]
  appointments Appointment[]
  rewards      LoyaltyReward[]
  reviews      Review[]
}

model Client {
  id             String   @id @default(cuid())
  salonId        String
  name           String
  phone          String?
  email          String?
  gender         String?
  birthday       DateTime?
  visitFrequency Int?     // days between visits
  styleNotes     String?
  loyaltyPoints  Int      @default(0)
  status         String   @default("active") // active | at_risk | lost
  averageSpend   Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salon        Salon          @relation(fields: [salonId], references: [id])
  appointments Appointment[]
  styleProfile StyleProfile?
  reviews      Review[]
}

model Appointment {
  id          String   @id @default(cuid())
  salonId     String
  clientId    String
  date        DateTime
  serviceType String
  duration    Int      // minutes
  price       Float
  status      String   @default("scheduled") // scheduled | confirmed | completed | no_show | cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon  Salon  @relation(fields: [salonId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}

model StyleProfile {
  id              String  @id @default(cuid())
  clientId        String  @unique
  salonType       String
  formulaOrGrade  String?
  preferencesJson String? // JSON

  client Client @relation(fields: [clientId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  salonId     String
  clientId    String?
  rating      Int
  platform    String   @default("google")
  requestedAt DateTime @default(now())

  salon  Salon   @relation(fields: [salonId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

model LoyaltyReward {
  id                 String @id @default(cuid())
  salonId            String
  tierName           String
  pointsRequired     Int
  rewardDescription  String

  salon Salon @relation(fields: [salonId], references: [id])
}
